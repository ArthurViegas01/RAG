# Build stage
FROM node:20-alpine AS builder

WORKDIR /app

COPY package*.json ./
RUN npm install

COPY . .

# Build para produção
RUN npm run build

# Runtime stage - servidor estático
FROM node:20-alpine

WORKDIR /app

# Instala serve para servir arquivos estáticos
RUN npm install -g serve

# Copia arquivos buildados do stage anterior
COPY --from=builder /app/dist ./dist

EXPOSE 5173

# Serve os arquivos estáticos em produção
CMD ["serve", "-s", "dist", "-l", "5173"]

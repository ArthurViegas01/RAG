# ========================================
# VARIÁVEIS DE PRODUÇÃO
# ========================================
# Copie este arquivo para .env.prod e preencha com seus valores reais
# cp .env.prod.example .env.prod
#
# NÃO COMMITE .env.prod no git!
#

# === DATABASE ===
# PostgreSQL credenciais - MUDE PARA VALORES SEGUROS EM PRODUÇÃO!
# Gere senhas fortes: openssl rand -base64 32
POSTGRES_USER=raguser
POSTGRES_PASSWORD=GERE_UMA_SENHA_FORTE_AQUI_32_CARACTERES
POSTGRES_DB=ragdb

# === REDIS ===
# Redis usa autenticação opcional (recomendado desabilitar em produção local)
# Se usar auth: redis://[:password]@host:port/db
REDIS_URL=redis://redis:6379/0

# === LLM PROVIDER ===
# Opções: "ollama" (local - NÃO recomendado em produção)
#         "groq" (gratuito - RECOMENDADO)
#         "openai" (pago)
LLM_PROVIDER=groq

# === GROQ (RECOMENDADO PARA PRODUÇÃO - GRATUITO) ===
# Obtenha a chave em https://console.groq.com
GROQ_API_KEY=gsk_COLE_SUA_CHAVE_AQUI
GROQ_MODEL=llama3-8b-8192

# === OLLAMA (Apenas se rodar em localhost, NÃO para VPS remota) ===
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=llama3

# === OPENAI (Alternativa paga) ===
# OPENAI_API_KEY=sk_COLE_SUA_CHAVE_AQUI
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# === CORS ===
# Domínios permitidos (separados por vírgula)
# IMPORTANTE: Adicione seu domínio de produção aqui!
# Ex: https://seudominio.com,https://www.seudominio.com
CORS_ORIGINS=https://seudominio.com

# === UPLOAD ===
# Diretório para upload de documentos (use volume no docker-compose)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# === CHUNKING (Fine-tuning) ===
CHUNK_SIZE=800
CHUNK_OVERLAP=150
MAX_CHUNKS_PER_DOC=2000

# === SEARCH / RAG ===
DEFAULT_TOP_K=8
MIN_SIMILARITY=0.15

# === EMBEDDINGS ===
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

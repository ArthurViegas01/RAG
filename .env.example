# === Database ===
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpass123
POSTGRES_DB=ragdb
DATABASE_URL=postgresql+asyncpg://raguser:ragpass123@localhost:5432/ragdb

# === Redis ===

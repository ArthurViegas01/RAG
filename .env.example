# Banco de Dados
# Railway injeta DATABASE_URL automaticamente com o plugin PostgreSQL
DATABASE_URL=postgresql+asyncpg://raguser:ragpass123@localhost:5432/ragdb

# Redis
# Railway injeta REDIS_URL automaticamente com o plugin Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# LLM Provider: "ollama" (dev local) | "groq" (producao gratuita) | "openai"
LLM_PROVIDER=groq

# Groq - chave gratuita em https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama3-8b-8192

# Ollama - apenas para dev local
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3

# OpenAI - alternativa paga
# OPENAI_API_KEY=sk-xxxx
# OPENAI_MODEL=gpt-4o-mini

# CORS - separe multiplas origens com virgula
CORS_ORIGINS=http://localhost:5173,https://contextrag.netlify.app

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
